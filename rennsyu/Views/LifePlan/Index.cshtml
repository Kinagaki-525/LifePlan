@using Microsoft.AspNetCore.Mvc.Rendering
@model LifePlanViewModel

@{
    ViewData["Title"] = "ライフプランシミュレーター";
    var childAgeOptions = new SelectList(Model.ChildAgeOptions, "Value", "Text");
    var occupationOptions = new SelectList(Model.OccupationOptions, "Value", "Text");
    var pensionReferenceOptions = new SelectList(Model.PensionReferenceOptions, "Value", "Text");
    var nurseryEducationOptions = new SelectList(Model.NurseryEducationOptions, "Value", "Text");
    var kindergartenEducationOptions = new SelectList(Model.KindergartenEducationOptions, "Value", "Text");
    var elementarySchoolEducationOptions = new SelectList(Model.ElementarySchoolEducationOptions, "Value", "Text");
    var juniorHighSchoolEducationOptions = new SelectList(Model.JuniorHighSchoolEducationOptions, "Value", "Text");
    var highSchoolEducationOptions = new SelectList(Model.HighSchoolEducationOptions, "Value", "Text");
    var universityEducationOptions = new SelectList(Model.UniversityEducationOptions, "Value", "Text");
    var graduateSchoolEducationOptions = new SelectList(Model.GraduateSchoolEducationOptions, "Value", "Text");
}

<section class="life-plan-simulator">
    <div class="mb-4">
        <p class="text-primary fw-bold mb-2">Life Plan Simulator</p>
        <h1 class="h2 fw-bold mb-2">ライフプランシミュレーター</h1>
        <p class="text-muted mb-0">
            家族構成、現在の貯蓄、夫婦それぞれの収入条件を入力して、試算に必要な基本情報を確認します。
        </p>
    </div>

    @if (Model.IsSubmitted)
    {
        <div class="alert alert-success" role="alert">
            入力内容を受け付けました。計算結果の表示は後続PRで実装します。
        </div>
    }

    <form asp-action="Index" method="post" novalidate>
        <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

        <div class="row g-4">
            <div class="col-lg-7">
                <section class="border rounded p-4 mb-3">
                    <h2 class="h5 fw-bold mb-3">家族構成</h2>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Family.HusbandAge" class="form-label">夫の年齢</label>
                            <input asp-for="Family.HusbandAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="Family.HusbandAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Family.WifeAge" class="form-label">妻の年齢</label>
                            <input asp-for="Family.WifeAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="Family.WifeAge" class="text-danger"></span>
                        </div>
                    </div>

                    <hr />

                    <div class="row g-3">
                        @for (var index = 0; index < Model.Family.Children.Count; index++)
                        {
                            <div class="col-md-6">
                                <input asp-for="Family.Children[index].Label" type="hidden" />
                                <label asp-for="Family.Children[index].Age" class="form-label">@Model.Family.Children[index].Label の年齢</label>
                                <select asp-for="Family.Children[index].Age" asp-items="childAgeOptions" class="form-select"></select>
                                <span asp-validation-for="Family.Children[index].Age" class="text-danger"></span>
                            </div>
                        }
                    </div>
                </section>

                <section class="border rounded p-4 mb-3">
                    <h2 class="h5 fw-bold mb-3">貯蓄</h2>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Savings.CurrentFinancialAssetsManYen" class="form-label">現在の金融資産残高（万円）</label>
                            <input asp-for="Savings.CurrentFinancialAssetsManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="Savings.CurrentFinancialAssetsManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Savings.ExpectedAnnualReturnRatePercent" class="form-label">想定運用年利（%）</label>
                            <input asp-for="Savings.ExpectedAnnualReturnRatePercent" class="form-control" type="number" min="0" max="20" step="0.1" />
                            <span asp-validation-for="Savings.ExpectedAnnualReturnRatePercent" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <section class="border rounded p-4 mb-3">
                    <h2 class="h5 fw-bold mb-3">夫の収入</h2>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.HusbandIncome.OccupationValue" class="form-label">職業</label>
                            <select asp-for="IncomeExpense.HusbandIncome.OccupationValue" asp-items="occupationOptions" class="form-select">
                                <option value="">選択してください</option>
                            </select>
                            <span asp-validation-for="IncomeExpense.HusbandIncome.OccupationValue" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.HusbandIncome.AnnualIncomeManYen" class="form-label">年収（万円）</label>
                            <input asp-for="IncomeExpense.HusbandIncome.AnnualIncomeManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.HusbandIncome.AnnualIncomeManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IncomeExpense.HusbandIncome.WorkStartAge" class="form-label">就労開始年齢</label>
                            <input asp-for="IncomeExpense.HusbandIncome.WorkStartAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="IncomeExpense.HusbandIncome.WorkStartAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IncomeExpense.HusbandIncome.WorkEndAge" class="form-label">就労終了年齢</label>
                            <input asp-for="IncomeExpense.HusbandIncome.WorkEndAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="IncomeExpense.HusbandIncome.WorkEndAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IncomeExpense.HusbandIncome.AnnualIncomeChangeRatePercent" class="form-label">年収の変化（%）</label>
                            <input asp-for="IncomeExpense.HusbandIncome.AnnualIncomeChangeRatePercent" class="form-control" type="number" step="0.1" />
                            <span asp-validation-for="IncomeExpense.HusbandIncome.AnnualIncomeChangeRatePercent" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.HusbandIncome.RetirementAllowanceManYen" class="form-label">退職金（万円）</label>
                            <input asp-for="IncomeExpense.HusbandIncome.RetirementAllowanceManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.HusbandIncome.RetirementAllowanceManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.HusbandIncome.PensionReferenceValue" class="form-label">年金参考値</label>
                            <select asp-for="IncomeExpense.HusbandIncome.PensionReferenceValue" asp-items="pensionReferenceOptions" class="form-select">
                                <option value="">選択してください</option>
                            </select>
                            <span asp-validation-for="IncomeExpense.HusbandIncome.PensionReferenceValue" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.HusbandIncome.AnnualPensionManYen" class="form-label">年金年額（万円）</label>
                            <input asp-for="IncomeExpense.HusbandIncome.AnnualPensionManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.HusbandIncome.AnnualPensionManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.HusbandIncome.PensionStartAge" class="form-label">年金受取開始年齢</label>
                            <input asp-for="IncomeExpense.HusbandIncome.PensionStartAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="IncomeExpense.HusbandIncome.PensionStartAge" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <section class="border rounded p-4 mb-3">
                    <h2 class="h5 fw-bold mb-3">妻の収入</h2>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.WifeIncome.OccupationValue" class="form-label">職業</label>
                            <select asp-for="IncomeExpense.WifeIncome.OccupationValue" asp-items="occupationOptions" class="form-select">
                                <option value="">選択してください</option>
                            </select>
                            <span asp-validation-for="IncomeExpense.WifeIncome.OccupationValue" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.WifeIncome.AnnualIncomeManYen" class="form-label">年収（万円）</label>
                            <input asp-for="IncomeExpense.WifeIncome.AnnualIncomeManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.WifeIncome.AnnualIncomeManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IncomeExpense.WifeIncome.WorkStartAge" class="form-label">就労開始年齢</label>
                            <input asp-for="IncomeExpense.WifeIncome.WorkStartAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="IncomeExpense.WifeIncome.WorkStartAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IncomeExpense.WifeIncome.WorkEndAge" class="form-label">就労終了年齢</label>
                            <input asp-for="IncomeExpense.WifeIncome.WorkEndAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="IncomeExpense.WifeIncome.WorkEndAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IncomeExpense.WifeIncome.AnnualIncomeChangeRatePercent" class="form-label">年収の変化（%）</label>
                            <input asp-for="IncomeExpense.WifeIncome.AnnualIncomeChangeRatePercent" class="form-control" type="number" step="0.1" />
                            <span asp-validation-for="IncomeExpense.WifeIncome.AnnualIncomeChangeRatePercent" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.WifeIncome.RetirementAllowanceManYen" class="form-label">退職金（万円）</label>
                            <input asp-for="IncomeExpense.WifeIncome.RetirementAllowanceManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.WifeIncome.RetirementAllowanceManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.WifeIncome.PensionReferenceValue" class="form-label">年金参考値</label>
                            <select asp-for="IncomeExpense.WifeIncome.PensionReferenceValue" asp-items="pensionReferenceOptions" class="form-select">
                                <option value="">選択してください</option>
                            </select>
                            <span asp-validation-for="IncomeExpense.WifeIncome.PensionReferenceValue" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.WifeIncome.AnnualPensionManYen" class="form-label">年金年額（万円）</label>
                            <input asp-for="IncomeExpense.WifeIncome.AnnualPensionManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.WifeIncome.AnnualPensionManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.WifeIncome.PensionStartAge" class="form-label">年金受取開始年齢</label>
                            <input asp-for="IncomeExpense.WifeIncome.PensionStartAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="IncomeExpense.WifeIncome.PensionStartAge" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <section class="border rounded p-4 mb-3">
                    <h2 class="h5 fw-bold mb-3">ライフイベント</h2>

                    <h3 class="h6 fw-bold mb-3">結婚</h3>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="LifeEvents.Marriage.CostManYen" class="form-label">費用（万円）</label>
                            <input asp-for="LifeEvents.Marriage.CostManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="LifeEvents.Marriage.CostManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LifeEvents.Marriage.HusbandAge" class="form-label">実施年齢（夫年齢）</label>
                            <input asp-for="LifeEvents.Marriage.HusbandAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="LifeEvents.Marriage.HusbandAge" class="text-danger"></span>
                        </div>
                    </div>

                    <h3 class="h6 fw-bold mb-3">住宅購入</h3>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="LifeEvents.Housing.PurchaseHusbandAge" class="form-label">購入時期（夫年齢）</label>
                            <input asp-for="LifeEvents.Housing.PurchaseHusbandAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="LifeEvents.Housing.PurchaseHusbandAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LifeEvents.Housing.DownPaymentManYen" class="form-label">頭金（万円）</label>
                            <input asp-for="LifeEvents.Housing.DownPaymentManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="LifeEvents.Housing.DownPaymentManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LifeEvents.Housing.BorrowingAmountManYen" class="form-label">借入額（万円）</label>
                            <input asp-for="LifeEvents.Housing.BorrowingAmountManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="LifeEvents.Housing.BorrowingAmountManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="LifeEvents.Housing.LoanYears" class="form-label">ローン年数</label>
                            <input asp-for="LifeEvents.Housing.LoanYears" class="form-control" type="number" min="1" />
                            <span asp-validation-for="LifeEvents.Housing.LoanYears" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="LifeEvents.Housing.InterestRatePercent" class="form-label">想定金利（%）</label>
                            <input asp-for="LifeEvents.Housing.InterestRatePercent" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="LifeEvents.Housing.InterestRatePercent" class="text-danger"></span>
                        </div>
                    </div>

                    <h3 class="h6 fw-bold mb-3">自動車</h3>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label asp-for="LifeEvents.Car.PurchaseAmountManYen" class="form-label">購入額（万円）</label>
                            <input asp-for="LifeEvents.Car.PurchaseAmountManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="LifeEvents.Car.PurchaseAmountManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LifeEvents.Car.FirstPurchaseHusbandAge" class="form-label">初回購入年齢（夫年齢）</label>
                            <input asp-for="LifeEvents.Car.FirstPurchaseHusbandAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="LifeEvents.Car.FirstPurchaseHusbandAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LifeEvents.Car.ReplacementIntervalYears" class="form-label">買い替え間隔（年）</label>
                            <input asp-for="LifeEvents.Car.ReplacementIntervalYears" class="form-control" type="number" min="1" />
                            <span asp-validation-for="LifeEvents.Car.ReplacementIntervalYears" class="text-danger"></span>
                        </div>
                    </div>

                    <h3 class="h6 fw-bold mb-3">教育費</h3>
                    @for (var index = 0; index < Model.LifeEvents.EducationPlans.Count; index++)
                    {
                        <div class="border rounded p-3 mb-3">
                            <input asp-for="LifeEvents.EducationPlans[index].Label" type="hidden" />
                            <h4 class="h6 fw-bold mb-3">@Model.LifeEvents.EducationPlans[index].Label</h4>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="LifeEvents.EducationPlans[index].NurseryOptionValue" class="form-label">保育園</label>
                                    <select asp-for="LifeEvents.EducationPlans[index].NurseryOptionValue" asp-items="nurseryEducationOptions" class="form-select">
                                        <option value="">選択してください</option>
                                    </select>
                                    <span asp-validation-for="LifeEvents.EducationPlans[index].NurseryOptionValue" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LifeEvents.EducationPlans[index].KindergartenOptionValue" class="form-label">幼稚園・保育園</label>
                                    <select asp-for="LifeEvents.EducationPlans[index].KindergartenOptionValue" asp-items="kindergartenEducationOptions" class="form-select">
                                        <option value="">選択してください</option>
                                    </select>
                                    <span asp-validation-for="LifeEvents.EducationPlans[index].KindergartenOptionValue" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LifeEvents.EducationPlans[index].ElementarySchoolOptionValue" class="form-label">小学校</label>
                                    <select asp-for="LifeEvents.EducationPlans[index].ElementarySchoolOptionValue" asp-items="elementarySchoolEducationOptions" class="form-select">
                                        <option value="">選択してください</option>
                                    </select>
                                    <span asp-validation-for="LifeEvents.EducationPlans[index].ElementarySchoolOptionValue" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LifeEvents.EducationPlans[index].JuniorHighSchoolOptionValue" class="form-label">中学校</label>
                                    <select asp-for="LifeEvents.EducationPlans[index].JuniorHighSchoolOptionValue" asp-items="juniorHighSchoolEducationOptions" class="form-select">
                                        <option value="">選択してください</option>
                                    </select>
                                    <span asp-validation-for="LifeEvents.EducationPlans[index].JuniorHighSchoolOptionValue" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LifeEvents.EducationPlans[index].HighSchoolOptionValue" class="form-label">高校</label>
                                    <select asp-for="LifeEvents.EducationPlans[index].HighSchoolOptionValue" asp-items="highSchoolEducationOptions" class="form-select">
                                        <option value="">選択してください</option>
                                    </select>
                                    <span asp-validation-for="LifeEvents.EducationPlans[index].HighSchoolOptionValue" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LifeEvents.EducationPlans[index].UniversityOptionValue" class="form-label">大学</label>
                                    <select asp-for="LifeEvents.EducationPlans[index].UniversityOptionValue" asp-items="universityEducationOptions" class="form-select">
                                        <option value="">選択してください</option>
                                    </select>
                                    <span asp-validation-for="LifeEvents.EducationPlans[index].UniversityOptionValue" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LifeEvents.EducationPlans[index].GraduateSchoolOptionValue" class="form-label">大学院</label>
                                    <select asp-for="LifeEvents.EducationPlans[index].GraduateSchoolOptionValue" asp-items="graduateSchoolEducationOptions" class="form-select">
                                        <option value="">選択してください</option>
                                    </select>
                                    <span asp-validation-for="LifeEvents.EducationPlans[index].GraduateSchoolOptionValue" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    }

                    <h3 class="h6 fw-bold mb-3">旅行・その他</h3>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="LifeEvents.TravelOther.AnnualCostManYen" class="form-label">年間費用（万円）</label>
                            <input asp-for="LifeEvents.TravelOther.AnnualCostManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="LifeEvents.TravelOther.AnnualCostManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LifeEvents.TravelOther.StartHusbandAge" class="form-label">開始年齢（夫年齢）</label>
                            <input asp-for="LifeEvents.TravelOther.StartHusbandAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="LifeEvents.TravelOther.StartHusbandAge" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LifeEvents.TravelOther.EndHusbandAge" class="form-label">終了年齢（夫年齢）</label>
                            <input asp-for="LifeEvents.TravelOther.EndHusbandAge" class="form-control" type="number" min="16" max="100" />
                            <span asp-validation-for="LifeEvents.TravelOther.EndHusbandAge" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <section class="border rounded p-4 mb-3">
                    <h2 class="h5 fw-bold mb-3">支出</h2>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.Expenses.MonthlyBasicLivingCostManYen" class="form-label">毎月の基本生活費（万円）</label>
                            <input asp-for="IncomeExpense.Expenses.MonthlyBasicLivingCostManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.Expenses.MonthlyBasicLivingCostManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.Expenses.InflationRatePercent" class="form-label">想定インフレ率（%）</label>
                            <input asp-for="IncomeExpense.Expenses.InflationRatePercent" class="form-control" type="number" min="0" max="5" step="0.1" />
                            <span asp-validation-for="IncomeExpense.Expenses.InflationRatePercent" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.Expenses.MonthlyRentManYen" class="form-label">毎月の家賃（万円）</label>
                            <input asp-for="IncomeExpense.Expenses.MonthlyRentManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.Expenses.MonthlyRentManYen" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IncomeExpense.Expenses.OtherAnnualCostManYen" class="form-label">その他支出（年間・万円）</label>
                            <input asp-for="IncomeExpense.Expenses.OtherAnnualCostManYen" class="form-control" type="number" min="0" step="0.1" />
                            <span asp-validation-for="IncomeExpense.Expenses.OtherAnnualCostManYen" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <button class="btn btn-primary" type="submit">
                    シミュレーション実行
                </button>
            </div>

            <div class="col-lg-5">
                <section class="border rounded p-4 bg-light">
                    <h2 class="h5 fw-bold mb-3">結果</h2>
                    <p class="text-muted mb-3">
                        PR3では入力受付と検証までを行います。サマリー、年次キャッシュフロー表、貯蓄推移グラフは後続PRで表示します。
                    </p>
                    <div class="border rounded bg-white p-3">
                        結果表示エリア
                    </div>
                </section>
            </div>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const purchaseAge = document.getElementById('LifeEvents_Housing_PurchaseHusbandAge');
            const housingFields = [
                'LifeEvents_Housing_DownPaymentManYen',
                'LifeEvents_Housing_BorrowingAmountManYen',
                'LifeEvents_Housing_LoanYears',
                'LifeEvents_Housing_InterestRatePercent'
            ].map((id) => document.getElementById(id)).filter(Boolean);

            const updateHousingFields = () => {
                const isEnabled = purchaseAge && purchaseAge.value.trim() !== '';

                housingFields.forEach((field) => {
                    field.disabled = !isEnabled;
                });
            };

            purchaseAge?.addEventListener('input', updateHousingFields);
            updateHousingFields();
        })();
    </script>
}
