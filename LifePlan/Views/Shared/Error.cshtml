@model ErrorViewModel
@{
    ViewData["Title"] = "エラー";
}

<h1 class="text-danger">エラーが発生しました。</h1>
<h2 class="text-danger">リクエストの処理中に問題が発生しました。</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>リクエスト ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>開発モード</h3>
<p>
    <strong>Development</strong> 環境に切り替えると、発生したエラーの詳細情報が表示されます。
</p>
<p>
    <strong>公開環境では Development 環境を有効にしないでください。</strong>
    例外に含まれる機密情報が利用者に表示される可能性があります。
    ローカルでデバッグする場合は、環境変数 <strong>ASPNETCORE_ENVIRONMENT</strong> を <strong>Development</strong> に設定し、アプリを再起動してください。
</p>
